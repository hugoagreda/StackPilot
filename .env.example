# StackPilot global environment example

# Core
NODE_ENV=development

# Shared services
AUTH_SERVICE_URL=http://localhost:4101
BILLING_SERVICE_URL=http://localhost:4102
ANALYTICS_SERVICE_URL=http://localhost:4103
NOTIFICATIONS_SERVICE_URL=http://localhost:4104

# Dashboard
DASHBOARD_API_URL=http://localhost:4201
DASHBOARD_WEB_URL=http://localhost:4200

# Infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379

# FastQR backend
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
FASTQR_DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require&connect_timeout=5
FASTQR_JWT_SECRET=your_secret_here
FASTQR_JWT_EXPIRE_MINUTES=60

# -> %23
@ -> %40
: -> %3A
/ -> %2F
? -> %3F
& -> %26
^ -> %5E
