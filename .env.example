# StackPilot global environment example

# Core
NODE_ENV=development

# Shared services
AUTH_SERVICE_URL=http://localhost:4101
BILLING_SERVICE_URL=http://localhost:4102
ANALYTICS_SERVICE_URL=http://localhost:4103
NOTIFICATIONS_SERVICE_URL=http://localhost:4104

# Dashboard
DASHBOARD_API_URL=http://localhost:4201
DASHBOARD_WEB_URL=http://localhost:4200

# Infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379

# FastQR backend
FASTQR_DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require&connect_timeout=5

# -> %23
@ -> %40
: -> %3A
/ -> %2F
? -> %3F
& -> %26
^ -> %5E

# Rental Price Estimator backend
RPE_APP_NAME=Rental Price Estimator API
RPE_APP_ENV=dev
RPE_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rental_estimator

# Cleaning Schedule Generator backend
CSG_APP_NAME=Cleaning Schedule Generator API
CSG_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cleaning_schedule
CSG_DEFAULT_CLEANING_DURATION_MINUTES=120
CSG_DEFAULT_OPEN_WINDOW_HOURS=24

